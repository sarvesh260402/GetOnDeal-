# GetOnDeal backend environment template

NODE_ENV=development
PORT=5000

# Local development (required by Phase 2)
MONGODB_URI=mongodb://localhost:27017/GetOnDeal
MONGODB_URI_LOCAL=mongodb://localhost:27017/GetOnDeal

# Production example (Atlas) - keep this for deployment switching
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority

JWT_SECRET=replace_with_strong_secret

# Comma separated, optional in production
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000,http://127.0.0.1:5500,http://localhost:5500
